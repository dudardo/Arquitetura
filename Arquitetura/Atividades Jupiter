      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Hits:    96  x 8          = 768 ns\n",
            "Misses:  4  x (8 + 70) = 312 ns\n",
            "T_medio = (768 + 312) / 100 = 10.8 ns\n"
          ]
        }
      ],
      "source": [
        "tc, tmp, h, n = 8, 70, 0.96, 100\n",
        "\n",
        "hits   = int(h * n)\n",
        "misses = n - hits\n",
        "t_h    = hits   * tc\n",
        "t_m    = misses * (tc + tmp)\n",
        "T      = t_h + t_m\n",
        "Tm     = T / n\n",
        "\n",
        "print(f\"Hits:    {hits}  x {tc}          = {t_h} ns\")\n",
        "print(f\"Misses:  {misses}  x ({tc} + {tmp}) = {t_m} ns\")\n",
        "print(f\"T_medio = ({t_h} + {t_m}) / {n} = {Tm} ns\")\n"
      ],
      "id": "hbYeoEIIIaeB"
