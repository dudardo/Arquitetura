      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "N     = 2^12 = 4096 células\n",
            "Total = 4096 × 2 B = 8192 B = 8 KB\n"
          ]
        }
      ],
      "source": [
        "N = 2**12\n",
        "bits_cel  = 16\n",
        "bytes_cel = bits_cel // 8\n",
        "total     = N * bytes_cel\n",
        "print(f\"N     = 2^12 = {N} células\")\n",
        "print(f\"Total = {N} × {bytes_cel} B = {total} B = {total//1024} KB\")\n"
      ],
      "id": "m-nR_UyGIad3"
