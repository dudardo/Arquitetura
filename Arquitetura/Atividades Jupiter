        "## Questão 14\n",
        "$C_{DRAM}(N) = 5 + 0{,}00001 \\cdot N$  |  $C_{SRAM}(N) = 1 + 0{,}00002 \\cdot N$\n"
      ],
      "id": "L4zgQxDJIaeB"
    },
    {
      "cell_type": "code",
      "execution_count": 13,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "1GAfxETQIaeB",
        "outputId": "7a4a882b-b495-4ecb-ef5a-8edaa5b94312"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Break-even: 5.0 + 1e-05*N = 1.0 + 2e-05*N\n",
            "N = (5.0 - 1.0) / (2e-05 - 1e-05) = 400000 bits\n",
            "DRAM mais barata para N > 400000 bits\n"
          ]
        }
      ],
      "source": [
        "ci_D, ci_S = 5.00, 1.00\n",
        "p_D,  p_S  = 0.00001, 0.00002\n",
        "\n",
        "# Break-even: ci_D + p_D*N = ci_S + p_S*N\n",
        "N = (ci_D - ci_S) / (p_S - p_D)\n",
        "\n",
        "print(f\"Break-even: {ci_D} + {p_D}*N = {ci_S} + {p_S}*N\")\n",
        "print(f\"N = ({ci_D} - {ci_S}) / ({p_S} - {p_D}) = {N:.0f} bits\")\n",
        "print(f\"DRAM mais barata para N > {N:.0f} bits\")\n"
      ],
      "id": "1GAfxETQIaeB"
